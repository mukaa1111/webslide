{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "slide_schema",
  "title": "ParsedDocument Schema",
  "description": "validator_agent가 사용하는 슬라이드 JSON 검증 스키마",
  "type": "object",
  "required": ["source_file", "meta", "slides"],
  "properties": {
    "source_file": {
      "type": "string",
      "minLength": 1
    },
    "raw_md_hash": {
      "type": "string"
    },
    "degraded": {
      "type": "boolean",
      "description": "repair_agent가 최소화 복구한 경우 true"
    },
    "meta": {
      "type": "object",
      "required": ["courseId"],
      "properties": {
        "courseId": {
          "type": "string",
          "minLength": 1,
          "description": "slug 형식 권장 (영소문자, 숫자, 하이픈)"
        },
        "title": {
          "type": "string",
          "maxLength": 200
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "level": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced"]
        },
        "duration": {
          "type": "integer",
          "minimum": 0
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "author": {
          "type": "string"
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index", "blocks"],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "title": {
            "type": ["string", "null"]
          },
          "layout": {
            "type": "string",
            "enum": ["default", "code-only", "bullet-list", "image-focus", "title-only", "diagram", "statement", "compare"]
          },
          "blocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["paragraph", "code", "list", "blockquote", "table", "image", "divider", "heading"]
                }
              }
            }
          },
          "notes": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
