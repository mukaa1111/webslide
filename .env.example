# === Supabase (필수) ===
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# === 경로 설정 (선택, 기본값 있음) ===
INPUTS_DIR=./inputs
PROCESSED_DIR=./processed
QUARANTINE_DIR=./quarantine
STATE_DIR=./state

# === 파이프라인 파라미터 (선택) ===
MAX_FILE_SIZE_MB=5
MIN_FILE_SIZE_BYTES=10
UPLOAD_RETRY_MAX=3
UPLOAD_RETRY_MIN_WAIT=2
UPLOAD_RETRY_MAX_WAIT=8

# === 로깅 ===
LOG_LEVEL=INFO
LOG_TO_FILE=false
